{
  "hosting": {

    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "finlit-616d8",
          "appId": "1:768641326836:android:56581d4e9f04c8cc4908a1",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "finlit-616d8",
          "appId": "1:768641326836:ios:690d8a068e464e004908a1",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "finlit-616d8",
          "configurations": {
            "android": "1:768641326836:android:56581d4e9f04c8cc4908a1",
            "ios": "1:768641326836:ios:690d8a068e464e004908a1",
            "web": "1:768641326836:web:727d4461d754e5474908a1"
          }
        }
      }
    }
  }
}
